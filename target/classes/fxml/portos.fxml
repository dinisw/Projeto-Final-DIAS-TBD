<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.dias.navios.ui.controller.PortoController"
      spacing="12">
    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

    <Label text="Gestao de Portos">
        <font><Font size="16.0"/></font>
    </Label>

    <TableView fx:id="tabela" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colNome"   text="Nome"   prefWidth="220"/>
            <TableColumn fx:id="colPais"   text="Pais"   prefWidth="160"/>
            <TableColumn fx:id="colCodigo" text="Codigo" prefWidth="120"/>
        </columns>
    </TableView>

    <GridPane hgap="10" vgap="8">
        <Label text="Nome:"            GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="campoNome"   GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Pais:"            GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="campoPais"   GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Codigo:"          GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="campoCodigo" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="10">
        <Button text="Novo"    onAction="#novo"/>
        <Button text="Guardar" onAction="#guardar"/>
        <Button text="Apagar"  onAction="#apagar"/>
    </HBox>

    <Label fx:id="labelMensagem"/>
</VBox>
