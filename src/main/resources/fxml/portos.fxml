<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.dias.navios.ui.controller.PortoController"
      spacing="0">

    <!-- Cabeçalho -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <padding><Insets top="16" right="20" bottom="10" left="20"/></padding>
        <Label text="⚓  Gestão de Portos">
            <font><Font size="18.0"/></font>
        </Label>
    </HBox>

    <Separator/>

    <!-- Barra de acções -->
    <ToolBar>
        <Button text="＋  Novo Porto" onAction="#novo">
            <tooltip><Tooltip text="Criar um novo porto (abre janela de diálogo)"/></tooltip>
        </Button>
        <Separator orientation="VERTICAL"/>
        <Button fx:id="btnEditar" text="✎  Editar" onAction="#editar" disable="true">
            <tooltip><Tooltip text="Editar porto seleccionado  (ou duplo-clique na linha)"/></tooltip>
        </Button>
        <Button fx:id="btnApagar" text="🗑  Apagar" onAction="#apagar" disable="true">
            <tooltip><Tooltip text="Apagar porto seleccionado"/></tooltip>
        </Button>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="labelMensagem"/>
        <padding><Insets right="8"/></padding>
    </ToolBar>

    <!-- Tabela -->
    <TableView fx:id="tabela" VBox.vgrow="ALWAYS">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
        <placeholder>
            <Label text="Nenhum porto registado.  Clique em '＋ Novo Porto' para começar."/>
        </placeholder>
        <columns>
            <TableColumn fx:id="colNome"   text="Nome do Porto"   prefWidth="280"/>
            <TableColumn fx:id="colPais"   text="País"            prefWidth="180"/>
            <TableColumn fx:id="colCodigo" text="Código UNLOCODE" prefWidth="140"/>
        </columns>
    </TableView>

</VBox>
