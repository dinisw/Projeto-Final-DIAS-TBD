<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.dias.navios.ui.controller.TripulanteController"
      spacing="0">

    <HBox alignment="CENTER_LEFT" spacing="10">
        <padding><Insets top="16" right="20" bottom="10" left="20"/></padding>
        <Label text="👤  Gestão de Tripulação">
            <font><Font size="18.0"/></font>
        </Label>
    </HBox>

    <Separator/>

    <ToolBar>
        <Button text="＋  Novo Tripulante" onAction="#novo">
            <tooltip><Tooltip text="Registar um novo tripulante (abre janela de diálogo)"/></tooltip>
        </Button>
        <Separator orientation="VERTICAL"/>
        <Button fx:id="btnEditar" text="✎  Editar" onAction="#editar" disable="true">
            <tooltip><Tooltip text="Editar tripulante seleccionado  (ou duplo-clique na linha)"/></tooltip>
        </Button>
        <Button fx:id="btnApagar" text="🗑  Apagar" onAction="#apagar" disable="true">
            <tooltip><Tooltip text="Apagar tripulante seleccionado"/></tooltip>
        </Button>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="labelMensagem"/>
        <padding><Insets right="8"/></padding>
    </ToolBar>

    <TableView fx:id="tabela" VBox.vgrow="ALWAYS">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
        <placeholder>
            <Label text="Nenhum tripulante registado.  Clique em '＋ Novo Tripulante' para começar."/>
        </placeholder>
        <columns>
            <TableColumn fx:id="colNome"        text="Nome"            prefWidth="200"/>
            <TableColumn fx:id="colCertificado" text="Nº Certificado"  prefWidth="130"/>
            <TableColumn fx:id="colFuncao"      text="Função"          prefWidth="120"/>
            <TableColumn fx:id="colEstado"      text="Disponibilidade" prefWidth="130"/>
            <TableColumn fx:id="colEmail"       text="Email"           prefWidth="220"/>
        </columns>
    </TableView>

</VBox>
