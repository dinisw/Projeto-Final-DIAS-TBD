<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.dias.navios.ui.controller.NavioController"
      spacing="8" style="-fx-padding: 12;">

    <Label text="Gestão de Navios" style="-fx-font-size: 16; -fx-font-weight: bold;"/>

    <HBox spacing="8">
        <TextField fx:id="campoPesquisa" promptText="Pesquisar por nome ou IMO..." prefWidth="300"/>
        <Button text="Pesquisar" onAction="#pesquisar"/>
        <Button text="Novo" onAction="#novoNavio"/>
    </HBox>

    <TableView fx:id="tabelaNavios" prefHeight="220" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colNome"      text="Nome"          prefWidth="180"/>
            <TableColumn fx:id="colIMO"       text="Código IMO"    prefWidth="120"/>
            <TableColumn fx:id="colTipo"      text="Tipo"          prefWidth="130"/>
            <TableColumn fx:id="colCapacidade" text="Capacidade"   prefWidth="110"/>
            <TableColumn fx:id="colEstado"    text="Estado"        prefWidth="110"/>
        </columns>
        <placeholder><Label text="Sem navios registados."/></placeholder>
    </TableView>

    <GridPane hgap="10" vgap="6">
        <Label text="Nome:"            GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="campoNome"   GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="220"/>

        <Label text="Código IMO:"      GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="campoIMO"    GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Tipo:"            GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <ComboBox fx:id="comboTipo"    GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="220"/>

        <Label text="Capacidade (ton):"      GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="campoCapacidade"   GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Nº Tanques:"            GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <TextField fx:id="campoTanques"      GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Bandeira:"              GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <TextField fx:id="campoBandeira"     GridPane.rowIndex="5" GridPane.columnIndex="1"/>

        <Label text="Ano Fabrico:"           GridPane.rowIndex="6" GridPane.columnIndex="0"/>
        <TextField fx:id="campoAno"          GridPane.rowIndex="6" GridPane.columnIndex="1"/>

        <Label text="Estado:"                GridPane.rowIndex="7" GridPane.columnIndex="0"/>
        <ComboBox fx:id="comboEstado"        GridPane.rowIndex="7" GridPane.columnIndex="1" prefWidth="220"/>

        <Label text="Porto Actual:"          GridPane.rowIndex="8" GridPane.columnIndex="0"/>
        <ComboBox fx:id="comboPorto"         GridPane.rowIndex="8" GridPane.columnIndex="1" prefWidth="220"/>
    </GridPane>

    <HBox spacing="10">
        <Button text="Guardar"  onAction="#guardarNavio"/>
        <Button text="Apagar"   onAction="#apagarNavio"/>
    </HBox>

    <Label fx:id="labelMensagem" style="-fx-text-fill: #c0392b;"/>

</VBox>
