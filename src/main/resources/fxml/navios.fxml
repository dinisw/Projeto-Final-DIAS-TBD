<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<VBox spacing="0" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.dias.navios.ui.controller.NavioController">

    <HBox alignment="CENTER_LEFT" style="-fx-padding: 12 16 8 16;">
        <Label text="🚢  Gestão de Navios">
            <font><Font size="20"/></font>
        </Label>
    </HBox>

    <Separator/>

    <ToolBar style="-fx-padding: 6 8 6 8;">
        <Button text="＋  Novo Navio" onAction="#novo" prefHeight="30">
            <tooltip><Tooltip text="Registar um novo navio petroleiro"/></tooltip>
        </Button>
        <Separator orientation="VERTICAL"/>
        <Button fx:id="btnEditar" text="✎  Editar" onAction="#editar" disable="true" prefHeight="30">
            <tooltip><Tooltip text="Editar o navio selecionado (ou duplo-clique na tabela)"/></tooltip>
        </Button>
        <Button fx:id="btnApagar" text="🗑  Apagar" onAction="#apagar" disable="true" prefHeight="30">
            <tooltip><Tooltip text="Apagar o navio selecionado"/></tooltip>
        </Button>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="labelMensagem" style="-fx-text-fill: #555; -fx-padding: 0 8 0 0;"/>
    </ToolBar>

    <Separator/>

    <TableView fx:id="tabela" VBox.vgrow="ALWAYS">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
        <placeholder>
            <Label text="Nenhum navio registado."/>
        </placeholder>
        <columns>
            <TableColumn fx:id="colNome"       text="Nome"         prefWidth="180"/>
            <TableColumn fx:id="colIMO"        text="Código IMO"   prefWidth="130"/>
            <TableColumn fx:id="colTipo"       text="Tipo"         prefWidth="140"/>
            <TableColumn fx:id="colCapacidade" text="Capacidade"   prefWidth="120"/>
            <TableColumn fx:id="colEstado"     text="Estado"       prefWidth="120"/>
            <TableColumn fx:id="colPorto"      text="Porto Atual"  prefWidth="160"/>
        </columns>
    </TableView>

</VBox>
