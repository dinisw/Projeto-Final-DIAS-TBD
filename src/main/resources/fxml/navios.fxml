<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.dias.navios.ui.controller.NavioController"
      spacing="12">
    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

    <Label text="Gestao de Navios">
        <font><Font size="16.0"/></font>
    </Label>

    <TableView fx:id="tabela" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colNome"       text="Nome"        prefWidth="160"/>
            <TableColumn fx:id="colIMO"        text="Codigo IMO"  prefWidth="110"/>
            <TableColumn fx:id="colTipo"       text="Tipo"        prefWidth="130"/>
            <TableColumn fx:id="colCapacidade" text="Capac. (t)"  prefWidth="90"/>
            <TableColumn fx:id="colEstado"     text="Estado"      prefWidth="120"/>
            <TableColumn fx:id="colPorto"      text="Porto atual" prefWidth="150"/>
        </columns>
    </TableView>

    <GridPane hgap="10" vgap="8">
        <Label text="Nome:"               GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="campoNome"      GridPane.rowIndex="0" GridPane.columnIndex="1"/>
        <Label text="Codigo IMO:"         GridPane.rowIndex="0" GridPane.columnIndex="2"/>
        <TextField fx:id="campoIMO"       GridPane.rowIndex="0" GridPane.columnIndex="3"/>

        <Label text="Tipo:"               GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <ComboBox fx:id="comboTipo"       GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        <Label text="Estado:"             GridPane.rowIndex="1" GridPane.columnIndex="2"/>
        <ComboBox fx:id="comboEstado"     GridPane.rowIndex="1" GridPane.columnIndex="3"/>

        <Label text="Capacidade (t):"     GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="campoCapacidade" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
        <Label text="Nº Tanques:"         GridPane.rowIndex="2" GridPane.columnIndex="2"/>
        <TextField fx:id="campoTanques"   GridPane.rowIndex="2" GridPane.columnIndex="3"/>

        <Label text="Bandeira:"           GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="campoBandeira"  GridPane.rowIndex="3" GridPane.columnIndex="1"/>
        <Label text="Ano de fabrico:"     GridPane.rowIndex="3" GridPane.columnIndex="2"/>
        <TextField fx:id="campoAno"       GridPane.rowIndex="3" GridPane.columnIndex="3"/>

        <Label text="Porto atual:"        GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <ComboBox fx:id="comboPorto"      GridPane.rowIndex="4" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="10">
        <Button text="Novo"    onAction="#novo"/>
        <Button text="Guardar" onAction="#guardar"/>
        <Button text="Apagar"  onAction="#apagar"/>
    </HBox>

    <Label fx:id="labelMensagem"/>
</VBox>
