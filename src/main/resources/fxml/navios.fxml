<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.dias.navios.ui.controller.NavioController"
      spacing="0">

    <HBox alignment="CENTER_LEFT" spacing="10">
        <padding><Insets top="16" right="20" bottom="10" left="20"/></padding>
        <Label text="🚢  Gestão de Navios">
            <font><Font size="18.0"/></font>
        </Label>
    </HBox>

    <Separator/>

    <ToolBar>
        <Button text="＋  Novo Navio" onAction="#novo">
            <tooltip><Tooltip text="Registar um novo navio (abre janela de diálogo)"/></tooltip>
        </Button>
        <Separator orientation="VERTICAL"/>
        <Button fx:id="btnEditar" text="✎  Editar" onAction="#editar" disable="true">
            <tooltip><Tooltip text="Editar navio seleccionado  (ou duplo-clique na linha)"/></tooltip>
        </Button>
        <Button fx:id="btnApagar" text="🗑  Apagar" onAction="#apagar" disable="true">
            <tooltip><Tooltip text="Apagar navio seleccionado"/></tooltip>
        </Button>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="labelMensagem"/>
        <padding><Insets right="8"/></padding>
    </ToolBar>

    <TableView fx:id="tabela" VBox.vgrow="ALWAYS">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
        <placeholder>
            <Label text="Nenhum navio registado.  Clique em '＋ Novo Navio' para começar."/>
        </placeholder>
        <columns>
            <TableColumn fx:id="colNome"       text="Nome"           prefWidth="180"/>
            <TableColumn fx:id="colIMO"        text="Código IMO"     prefWidth="110"/>
            <TableColumn fx:id="colTipo"       text="Tipo"           prefWidth="140"/>
            <TableColumn fx:id="colCapacidade" text="Capacidade"     prefWidth="100"/>
            <TableColumn fx:id="colEstado"     text="Estado"         prefWidth="120"/>
            <TableColumn fx:id="colPorto"      text="Porto Atual"    prefWidth="160"/>
        </columns>
    </TableView>

</VBox>
