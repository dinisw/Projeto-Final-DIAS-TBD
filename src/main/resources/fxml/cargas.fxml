<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.dias.navios.ui.controller.CargaController"
      spacing="8" style="-fx-padding: 12;">

    <Label text="Gestão de Cargas" style="-fx-font-size: 16; -fx-font-weight: bold;"/>

    <HBox spacing="8">
        <TextField fx:id="campoPesquisa" promptText="Pesquisar por designação..." prefWidth="300"/>
        <Button text="Pesquisar" onAction="#pesquisar"/>
        <Button text="Nova"      onAction="#novaCarga"/>
    </HBox>

    <TableView fx:id="tabelaCargas" prefHeight="200" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colDesignacao" text="Designação"  prefWidth="200"/>
            <TableColumn fx:id="colTipo"       text="Tipo"        prefWidth="140"/>
            <TableColumn fx:id="colVolume"     text="Volume"      prefWidth="100"/>
            <TableColumn fx:id="colPeso"       text="Peso"        prefWidth="100"/>
        </columns>
        <placeholder><Label text="Sem cargas registadas."/></placeholder>
    </TableView>

    <GridPane hgap="10" vgap="6">
        <Label text="Designação:"              GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="campoDesignacao"     GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="220"/>

        <Label text="Tipo:"                    GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <ComboBox fx:id="comboTipo"            GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="220"/>

        <Label text="Volume (m³):"             GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="campoVolume"         GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Peso (ton):"              GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="campoPeso"           GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Inflamável:"              GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <CheckBox fx:id="checkInflamavel"      GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Corrosiva:"               GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <CheckBox fx:id="checkCorrosiva"       GridPane.rowIndex="5" GridPane.columnIndex="1"/>

        <Label text="Tóxica:"                  GridPane.rowIndex="6" GridPane.columnIndex="0"/>
        <CheckBox fx:id="checkToxica"          GridPane.rowIndex="6" GridPane.columnIndex="1"/>

        <Label text="Porto Carregamento:"              GridPane.rowIndex="7" GridPane.columnIndex="0"/>
        <ComboBox fx:id="comboPortoCarregamento"       GridPane.rowIndex="7" GridPane.columnIndex="1" prefWidth="220"/>

        <Label text="Porto Descarga:"                  GridPane.rowIndex="8" GridPane.columnIndex="0"/>
        <ComboBox fx:id="comboPortoDescarga"           GridPane.rowIndex="8" GridPane.columnIndex="1" prefWidth="220"/>
    </GridPane>

    <HBox spacing="10">
        <Button text="Guardar" onAction="#guardarCarga"/>
        <Button text="Apagar"  onAction="#apagarCarga"/>
    </HBox>

    <Label fx:id="labelMensagem" style="-fx-text-fill: #c0392b;"/>

</VBox>
