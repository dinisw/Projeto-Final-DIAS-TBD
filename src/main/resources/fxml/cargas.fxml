<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.dias.navios.ui.controller.CargaController"
      spacing="12">
    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

    <Label text="Gestao de Cargas">
        <font><Font size="16.0"/></font>
    </Label>

    <TableView fx:id="tabela" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colDesignacao" text="Designacao"   prefWidth="170"/>
            <TableColumn fx:id="colTipo"       text="Tipo"         prefWidth="130"/>
            <TableColumn fx:id="colVolume"     text="Volume (m3)"  prefWidth="90"/>
            <TableColumn fx:id="colPeso"       text="Peso (t)"     prefWidth="80"/>
            <TableColumn fx:id="colInflamavel" text="Inflamavel"   prefWidth="80"/>
            <TableColumn fx:id="colCarga"      text="P. Carga"     prefWidth="120"/>
            <TableColumn fx:id="colDescarga"   text="P. Descarga"  prefWidth="120"/>
        </columns>
    </TableView>

    <GridPane hgap="10" vgap="8">
        <Label text="Designacao:"             GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="campoDesignacao"    GridPane.rowIndex="0" GridPane.columnIndex="1"/>
        <Label text="Tipo:"                   GridPane.rowIndex="0" GridPane.columnIndex="2"/>
        <ComboBox fx:id="comboTipo"           GridPane.rowIndex="0" GridPane.columnIndex="3"/>

        <Label text="Volume (m3):"            GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="campoVolume"        GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        <Label text="Peso (t):"               GridPane.rowIndex="1" GridPane.columnIndex="2"/>
        <TextField fx:id="campoPeso"          GridPane.rowIndex="1" GridPane.columnIndex="3"/>

        <Label text="Propriedades (do tipo):"  GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <CheckBox fx:id="checkInflamavel" text="Inflamavel" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
        <CheckBox fx:id="checkCorrosiva"  text="Corrosiva"  GridPane.rowIndex="2" GridPane.columnIndex="2"/>
        <CheckBox fx:id="checkToxica"     text="Toxica"     GridPane.rowIndex="2" GridPane.columnIndex="3"/>

        <Label text="Porto de carga:"         GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <ComboBox fx:id="comboPortoCarga"     GridPane.rowIndex="3" GridPane.columnIndex="1"/>
        <Label text="Porto de descarga:"      GridPane.rowIndex="3" GridPane.columnIndex="2"/>
        <ComboBox fx:id="comboPortoDescarga"  GridPane.rowIndex="3" GridPane.columnIndex="3"/>
    </GridPane>

    <HBox spacing="10">
        <Button text="Novo"    onAction="#novo"/>
        <Button text="Guardar" onAction="#guardar"/>
        <Button text="Apagar"  onAction="#apagar"/>
    </HBox>

    <Label fx:id="labelMensagem"/>
</VBox>
