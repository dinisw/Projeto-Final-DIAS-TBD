<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<VBox spacing="0" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.dias.navios.ui.controller.CargaController">

    <HBox alignment="CENTER_LEFT">
        <padding><Insets top="12" right="16" bottom="8" left="16"/></padding>
        <Label text="🛢  Gestão de Cargas">
            <font><Font size="20"/></font>
        </Label>
    </HBox>

    <Separator/>

    <ToolBar>
        <Button text="＋  Nova Carga" onAction="#novo" prefHeight="30">
            <tooltip><Tooltip text="Registar uma nova carga"/></tooltip>
        </Button>
        <Separator orientation="VERTICAL"/>
        <Button fx:id="btnEditar" text="✎  Editar" onAction="#editar" disable="true" prefHeight="30">
            <tooltip><Tooltip text="Editar a carga selecionada (ou duplo-clique na tabela)"/></tooltip>
        </Button>
        <Button fx:id="btnApagar" text="🗑  Apagar" onAction="#apagar" disable="true" prefHeight="30">
            <tooltip><Tooltip text="Apagar a carga selecionada"/></tooltip>
        </Button>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="labelMensagem"/>
    </ToolBar>

    <Separator/>

    <TableView fx:id="tabela" VBox.vgrow="ALWAYS">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
        <placeholder>
            <Label text="Nenhuma carga registada."/>
        </placeholder>
        <columns>
            <TableColumn fx:id="colDesignacao" text="Designação"   prefWidth="200"/>
            <TableColumn fx:id="colTipo"       text="Tipo"         prefWidth="130"/>
            <TableColumn fx:id="colVolume"     text="Volume"       prefWidth="100"/>
            <TableColumn fx:id="colPeso"       text="Peso"         prefWidth="100"/>
            <TableColumn fx:id="colInflamavel" text="Propriedades" prefWidth="110"/>
            <TableColumn fx:id="colCarga"      text="Porto Carga"  prefWidth="150"/>
            <TableColumn fx:id="colDescarga"   text="Porto Descarga" prefWidth="150"/>
        </columns>
    </TableView>

</VBox>
