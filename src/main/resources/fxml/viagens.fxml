<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.dias.navios.ui.controller.ViagemController"
      spacing="8" style="-fx-padding: 12;">

    <Label text="Gestão de Viagens" style="-fx-font-size: 16; -fx-font-weight: bold;"/>

    <HBox spacing="8">
        <TextField fx:id="campoPesquisa" promptText="Filtrar por estado ou ID..." prefWidth="280"/>
        <Button text="Pesquisar" onAction="#pesquisar"/>
        <Button text="Nova"      onAction="#novaViagem"/>
    </HBox>

    <TableView fx:id="tabelaViagens" prefHeight="180">
        <columns>
            <TableColumn fx:id="colViagemId"      text="ID"       prefWidth="50"/>
            <TableColumn fx:id="colViagemNavio"   text="Navio"    prefWidth="100"/>
            <TableColumn fx:id="colViagemOrigem"  text="Origem"   prefWidth="100"/>
            <TableColumn fx:id="colViagemDestino" text="Destino"  prefWidth="100"/>
            <TableColumn fx:id="colViagemPartida" text="Partida"  prefWidth="100"/>
            <TableColumn fx:id="colViagemEstado"  text="Estado"   prefWidth="100"/>
        </columns>
        <placeholder><Label text="Sem viagens registadas."/></placeholder>
    </TableView>

    <!-- Formulário base -->
    <GridPane hgap="10" vgap="6">
        <Label text="Navio:"               GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <ComboBox fx:id="comboNavio"       GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="220"/>

        <Label text="Porto Origem:"         GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <ComboBox fx:id="comboPortoOrigem"  GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="220"/>

        <Label text="Porto Destino:"        GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <ComboBox fx:id="comboPortoDestino" GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="220"/>

        <Label text="Data Partida:"         GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <DatePicker fx:id="campoDataPartida" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Data Chegada Prevista:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <DatePicker fx:id="campoDataChegada" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
    </GridPane>

    <!-- Capacidade -->
    <Label fx:id="labelCapacidade" style="-fx-text-fill: #2980b9; -fx-font-style: italic;"/>

    <!-- Cargas -->
    <Label text="Cargas:" style="-fx-font-weight: bold;"/>
    <HBox spacing="6">
        <VBox spacing="4" prefWidth="300">
            <Label text="Disponíveis:"/>
            <ListView fx:id="listaCargasDisponiveis" prefHeight="100"/>
        </VBox>
        <VBox alignment="CENTER" spacing="6" style="-fx-padding: 20 0 0 0;">
            <Button text="→" onAction="#adicionarCarga"    prefWidth="36"/>
            <Button text="←" onAction="#removerCarga"      prefWidth="36"/>
        </VBox>
        <VBox spacing="4" prefWidth="300">
            <Label text="Na Viagem:"/>
            <ListView fx:id="listaCargasSelecionadas" prefHeight="100"/>
        </VBox>
    </HBox>

    <!-- Tripulantes -->
    <Label text="Tripulantes:" style="-fx-font-weight: bold;"/>
    <HBox spacing="6">
        <VBox spacing="4" prefWidth="300">
            <Label text="Disponíveis:"/>
            <ListView fx:id="listaTripulantesDisponiveis" prefHeight="100"/>
        </VBox>
        <VBox alignment="CENTER" spacing="6" style="-fx-padding: 20 0 0 0;">
            <Button text="→" onAction="#adicionarTripulante"  prefWidth="36"/>
            <Button text="←" onAction="#removerTripulante"    prefWidth="36"/>
        </VBox>
        <VBox spacing="4" prefWidth="300">
            <Label text="Na Viagem:"/>
            <ListView fx:id="listaTripulantesSelecionados" prefHeight="100"/>
        </VBox>
    </HBox>

    <!-- Botões de acção -->
    <HBox spacing="8">
        <Button text="Criar Viagem"    onAction="#criarViagem"/>
        <Button text="Guardar Edição"  onAction="#editarViagem"/>
        <Button text="Avançar Estado"  onAction="#avancarEstado"/>
        <Button text="Cancelar"        onAction="#cancelarViagem"/>
    </HBox>

    <Label fx:id="labelMensagem" style="-fx-text-fill: #c0392b;"/>

</VBox>
