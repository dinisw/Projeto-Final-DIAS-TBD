<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.dias.navios.ui.controller.ViagemController"
      spacing="0">

    <HBox alignment="CENTER_LEFT" spacing="10">
        <padding><Insets top="16" right="20" bottom="10" left="20"/></padding>
        <Label text="🗺  Gestão de Viagens">
            <font><Font size="18.0"/></font>
        </Label>
    </HBox>

    <Separator/>

    <!-- Toolbar: acções sobre viagens -->
    <ToolBar>
        <Button text="＋  Nova Viagem" onAction="#novo">
            <tooltip><Tooltip text="Planear uma nova viagem (abre janela de diálogo)"/></tooltip>
        </Button>
        <Separator orientation="VERTICAL"/>
        <Button fx:id="btnEditar" text="✎  Editar" onAction="#editar" disable="true">
            <tooltip><Tooltip text="Editar viagem seleccionada — só possível em estado PLANEADA"/></tooltip>
        </Button>
        <Separator orientation="VERTICAL"/>
        <Button fx:id="btnAvancar" text="▶  Avançar Estado" onAction="#avancarEstado" disable="true">
            <tooltip><Tooltip text="PLANEADA → EM CURSO → CONCLUÍDA"/></tooltip>
        </Button>
        <Button fx:id="btnCancelar" text="✖  Cancelar Viagem" onAction="#cancelarViagem" disable="true">
            <tooltip><Tooltip text="Cancelar a viagem seleccionada (só PLANEADA ou EM CURSO)"/></tooltip>
        </Button>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="labelMensagem"/>
        <padding><Insets right="8"/></padding>
    </ToolBar>

    <!-- Tabela principal de viagens -->
    <TableView fx:id="tabela" VBox.vgrow="ALWAYS" prefHeight="200">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
        <placeholder>
            <Label text="Nenhuma viagem planeada.  Clique em '＋ Nova Viagem' para começar."/>
        </placeholder>
        <columns>
            <TableColumn fx:id="colId"          text="#"              prefWidth="40"/>
            <TableColumn fx:id="colNavio"        text="Navio"          prefWidth="160"/>
            <TableColumn fx:id="colOrigem"       text="Origem"         prefWidth="120"/>
            <TableColumn fx:id="colDestino"      text="Destino"        prefWidth="120"/>
            <TableColumn fx:id="colPartida"      text="Partida"        prefWidth="95"/>
            <TableColumn fx:id="colChegada"      text="Chegada Prev."  prefWidth="95"/>
            <TableColumn fx:id="colChegadaReal"  text="Chegada Real"   prefWidth="95"/>
            <TableColumn fx:id="colEstado"       text="Estado"         prefWidth="110"/>
        </columns>
    </TableView>

    <!-- Painel de detalhe (cargas e tripulantes da viagem seleccionada) -->
    <TabPane VBox.vgrow="ALWAYS" prefHeight="240">

        <!-- TAB: Cargas -->
        <Tab text="📦  Cargas da Viagem" closable="false">
            <VBox spacing="8">
                <padding><Insets top="8" right="12" bottom="8" left="12"/></padding>

                <TableView fx:id="tabelaCargas" VBox.vgrow="ALWAYS" prefHeight="130">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                    <placeholder><Label text="Selecione uma viagem na tabela para ver as suas cargas."/></placeholder>
                    <columns>
                        <TableColumn fx:id="colCargaDesignacao" text="Designação"   prefWidth="220"/>
                        <TableColumn fx:id="colCargaTipo"       text="Tipo"          prefWidth="140"/>
                        <TableColumn fx:id="colCargaPeso"       text="Peso (t)"      prefWidth="90"/>
                        <TableColumn fx:id="colCargaVolume"     text="Volume (m³)"   prefWidth="90"/>
                    </columns>
                </TableView>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <ComboBox fx:id="comboCarga" prefWidth="300"
                              promptText="Selecione uma carga para associar…"/>
                    <Button text="＋  Adicionar" onAction="#adicionarCarga">
                        <tooltip><Tooltip text="Associar a carga seleccionada a esta viagem"/></tooltip>
                    </Button>
                    <Button text="－  Remover" onAction="#removerCarga">
                        <tooltip><Tooltip text="Remover a carga seleccionada da lista acima"/></tooltip>
                    </Button>
                </HBox>
            </VBox>
        </Tab>

        <!-- TAB: Tripulação -->
        <Tab text="👥  Tripulação da Viagem" closable="false">
            <VBox spacing="8">
                <padding><Insets top="8" right="12" bottom="8" left="12"/></padding>

                <TableView fx:id="tabelaTripulantes" VBox.vgrow="ALWAYS" prefHeight="130">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                    <placeholder><Label text="Selecione uma viagem na tabela para ver a sua tripulação."/></placeholder>
                    <columns>
                        <TableColumn fx:id="colTripNome"        text="Nome"            prefWidth="220"/>
                        <TableColumn fx:id="colTripFuncao"      text="Função"          prefWidth="130"/>
                        <TableColumn fx:id="colTripCertificado" text="Certificado"     prefWidth="130"/>
                        <TableColumn fx:id="colTripDisponivel"  text="Disponibilidade" prefWidth="130"/>
                    </columns>
                </TableView>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <ComboBox fx:id="comboTripulante" prefWidth="300"
                              promptText="Selecione um tripulante para associar…"/>
                    <Button text="＋  Adicionar" onAction="#adicionarTripulante">
                        <tooltip><Tooltip text="Associar o tripulante seleccionado a esta viagem"/></tooltip>
                    </Button>
                    <Button text="－  Remover" onAction="#removerTripulante">
                        <tooltip><Tooltip text="Remover o tripulante seleccionado da lista acima"/></tooltip>
                    </Button>
                </HBox>
            </VBox>
        </Tab>

    </TabPane>

</VBox>
