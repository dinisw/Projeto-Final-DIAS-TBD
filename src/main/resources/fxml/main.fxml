<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.dias.navios.ui.controller.MainController"
            fx:id="rootPane">

    <!-- ── Header ─────────────────────────────────────────────────────── -->
    <top>
        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #1a1a2e; -fx-padding: 10 20 10 20;" spacing="12">
            <Label text="⚓" style="-fx-text-fill: white;">
                <font><Font size="26"/></font>
            </Label>
            <VBox spacing="1">
                <Label text="SMF — Sistema de Gestão de Navios Petroleiros"
                       style="-fx-text-fill: white; -fx-font-weight: bold;">
                    <font><Font size="15"/></font>
                </Label>
                <Label text="ISEP · DIAS 2025/26"
                       style="-fx-text-fill: #aaaacc;">
                    <font><Font size="11"/></font>
                </Label>
            </VBox>
        </HBox>
    </top>

    <!-- ── Sidebar ────────────────────────────────────────────────────── -->
    <left>
        <VBox spacing="4" style="-fx-background-color: #f4f4f8; -fx-border-color: #ddd; -fx-border-width: 0 1 0 0;">
            <padding><Insets top="16" right="12" bottom="16" left="12"/></padding>

            <Label text="FROTA" style="-fx-text-fill: #888; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 0 0 2 4;"/>
            <Button text="🚢  Navios"      onAction="#abrirNavios"     maxWidth="Infinity" prefHeight="34" alignment="CENTER_LEFT" style="-fx-padding: 0 12;"/>
            <Button text="⚓  Portos"      onAction="#abrirPortos"     maxWidth="Infinity" prefHeight="34" alignment="CENTER_LEFT" style="-fx-padding: 0 12;"/>

            <Separator style="-fx-padding: 4 0;"/>

            <Label text="OPERAÇÕES" style="-fx-text-fill: #888; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 0 0 2 4;"/>
            <Button text="🗺  Viagens"     onAction="#abrirViagens"    maxWidth="Infinity" prefHeight="34" alignment="CENTER_LEFT" style="-fx-padding: 0 12;"/>
            <Button text="🛢  Cargas"      onAction="#abrirCargas"     maxWidth="Infinity" prefHeight="34" alignment="CENTER_LEFT" style="-fx-padding: 0 12;"/>
            <Button text="👤  Tripulantes" onAction="#abrirTripulacao" maxWidth="Infinity" prefHeight="34" alignment="CENTER_LEFT" style="-fx-padding: 0 12;"/>
        </VBox>
    </left>

    <!-- ── Welcome screen ─────────────────────────────────────────────── -->
    <center>
        <VBox alignment="CENTER" spacing="12" style="-fx-background-color: white;">
            <Label text="⚓" style="-fx-text-fill: #ccccdd;">
                <font><Font size="64"/></font>
            </Label>
            <Label text="Bem-vindo ao SMF" style="-fx-text-fill: #444;">
                <font><Font size="22"/></font>
            </Label>
            <Label text="Selecione um módulo na barra lateral para começar."
                   style="-fx-text-fill: #888;">
                <font><Font size="13"/></font>
            </Label>
        </VBox>
    </center>

</BorderPane>
